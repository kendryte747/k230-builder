#!/bin/bash
# k230 — Wrap k230-builder Docker container, pass any command through.
#
# Install:  cp k230 ~/.local/bin/  (or anywhere on $PATH)
# Usage:    k230 make CONF=k230_canmv_defconfig
#           k230 bash
#           k230 make
#
# All args after the script name are passed to the container as the command.

set -e

# ---- Check Docker ----
if ! command -v docker > /dev/null 2>&1; then
    echo "[k230] Docker is not installed. Please install Docker first:"
    echo "  Ubuntu/Debian: sudo apt install docker.io"
    echo "  macOS:         https://docs.docker.com/desktop/setup/install/mac-install/"
    echo "  Windows:       https://docs.docker.com/desktop/setup/install/windows-install/"
    echo "  China mirror:  https://mirrors.tuna.tsinghua.edu.cn/docker-ce/"
    exit 1
fi

# ---- Image resolution ----
TAG="${K230_BUILDER_TAG:-latest}"

if [ -n "${K230_BUILDER_IMAGE}" ]; then
    IMAGE="${K230_BUILDER_IMAGE}"
else
    IMAGE="ghcr.io/huangzhenming/k230-builder:${TAG}"
fi

MIRROR="registry.kendryte.com/k230-builder:${TAG}"

VOLUME="${K230_BUILDER_VOLUME:-k230_toolchains}"

# ---- Ensure image is available (local-first, ghcr-first) ----
ensure_image() {
    local target="${1:-$IMAGE}"

    # Already exists locally
    if docker image inspect "$target" > /dev/null 2>&1; then
        return 0
    fi

    echo "[k230] image $target not found locally, pulling..."

    # Quick pre-check: can we even reach ghcr?
    local ghcr_ok=0
    if [ "$target" != "$MIRROR" ]; then
        if timeout 5 curl -sfI --connect-timeout 3 "https://ghcr.io/v2/" > /dev/null 2>&1; then
            ghcr_ok=1
        else
            echo "[k230] ghcr.io unreachable, switching to mirror"
        fi
    fi

    # Try ghcr (300s = ~3MB/s floor for 1GB image)
    if [ "$ghcr_ok" = "1" ] && timeout 300 docker pull "$target"; then
        echo "[k230] pulled from ghcr.io"
        return 0
    fi

    # Fallback: pull from mirror, then tag to canonical name
    echo "[k230] pulling from mirror..."
    if timeout 600 docker pull "$MIRROR"; then
        if [ "$target" != "$MIRROR" ]; then
            docker tag "$MIRROR" "$target"
            echo "[k230] tagged $MIRROR -> $target"
        fi
        return 0
    fi

    echo "[k230] error: failed to pull image from all sources"
    return 1
}

# ---- Handle special commands ----
case "${1:-}" in
    pull|update)
        PULL_IMAGE="$IMAGE"
        if [ -n "${2:-}" ]; then
            PULL_IMAGE="${IMAGE%:*}:${2}"
        fi
        echo "[k230] pulling $PULL_IMAGE ..."
        docker pull "$PULL_IMAGE" || {
            echo "[k230] ghcr pull failed, trying mirror..."
            docker pull "$MIRROR" || {
                echo "[k230] pull failed"
                exit 1
            }
            if [ "$PULL_IMAGE" != "$MIRROR" ]; then
                docker tag "$MIRROR" "$PULL_IMAGE"
                echo "[k230] tagged $MIRROR -> $PULL_IMAGE"
            fi
        }
        exit 0
        ;;
    download-toolchains)
        ;;&
    help|--help|-h)
        echo "k230 — K230 SDK build wrapper"
        echo ""
        echo "Usage:"
        echo "  k230 make CONF=k230_canmv_defconfig   build SDK"
        echo "  k230 bash                              enter container shell"
        echo "  k230 pull [tag]                        pull Docker image (default: latest)"
        echo "  k230 download-toolchains [-l] [TC1 ..] download toolchains"
        echo "  k230 help                              show this message"
        echo ""
        echo "Any other command is passed through to the container."
        exit 0
        ;;
esac

ensure_image

# ---- Auto-mount host SSH keys, Git config, and Docker socket ----
EXTRA_MOUNTS=()
[ -d "$HOME/.ssh" ]     && EXTRA_MOUNTS+=(-v "$HOME/.ssh:/tmp/host-ssh:ro")
[ -f "$HOME/.gitconfig" ] && EXTRA_MOUNTS+=(-v "$HOME/.gitconfig:/tmp/host-gitconfig:ro")
[ -n "$K230_GIT_MIRROR" ] && [ -d "$K230_GIT_MIRROR" ] && EXTRA_MOUNTS+=(-v "$K230_GIT_MIRROR:$K230_GIT_MIRROR:ro")

# Docker socket: check access before mounting
if [ -S /var/run/docker.sock ]; then
    if docker info > /dev/null 2>&1; then
        EXTRA_MOUNTS+=(-v /var/run/docker.sock:/var/run/docker.sock)
    else
        echo "[k230] warning: cannot access /var/run/docker.sock. To fix:"
        echo "  sudo usermod -aG docker $USER && newgrp docker"
    fi
fi

# 限制并发数，防止因并发过高触发 host-dbus-glib 等包的编译 Bug
# 建议用户手动传入 -j 参数，否则默认使用 nproc
MAKE_J_LEVEL="-j$(nproc)"

exec docker run -it --rm \
    --security-opt seccomp=unconfined \
    --ulimit nofile=1024:2048 \
    -e HOST_UID="$(id -u)" \
    -e HOST_GID="$(id -g)" \
    -e ENABLE_TC4="${ENABLE_TC4:-0}" \
    -v "${VOLUME}:/opt/toolchains" \
    -v "$(pwd):/workspace" \
    -w /workspace \
    "${EXTRA_MOUNTS[@]}" \
    "$IMAGE" \
    "$@"
