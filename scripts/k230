#!/bin/bash
set -e

source /usr/local/bin/toolchain.sh

# ===== Argument parsing (URL overrides) =====
for arg in "$@"; do
    case $arg in
        tc1_urls=*)
            TC1_URLS=$(echo "${arg#*=}" | tr ',' ' ')
            ;;
        tc2_urls=*)
            TC2_URLS=$(echo "${arg#*=}" | tr ',' ' ')
            ;;
        tc3_urls=*)
            TC3_URLS=$(echo "${arg#*=}" | tr ',' ' ')
            ;;
        tc4_urls=*)
            TC4_URLS=$(echo "${arg#*=}" | tr ',' ' ')
            ;;
        linux_urls=*)
            TC2_URLS=$(echo "${arg#*=}" | tr ',' ' ')
            ;;
        rtos_urls=*)
            TC1_URLS=$(echo "${arg#*=}" | tr ',' ' ')
            TC3_URLS=$(echo "${arg#*=}" | tr ',' ' ')
            ;;
    esac
done

CMD=${1:-}

# ===== Helper: check if a toolchain is installed =====
# Returns 0 + prints version if installed, returns 1 if not installed
tc_is_installed() {
    local DIR=$1
    local VERSION=$2
    local BIN_FULL=$3

    if [ ! -f "$DIR/.installed" ] || [ ! -f "$DIR/.version" ]; then
        return 1
    fi

    if [ "$(cat "$DIR/.version")" != "$VERSION" ]; then
        return 1
    fi

    if [ ! -f "$DIR/$BIN_FULL" ]; then
        return 1
    fi

    return 0
}

# ===== Command: setup (download toolchains) =====
cmd_setup() {
    local target=${1:-}

    if [ -z "$target" ] || [ "$target" = "all" ]; then
        # Download all enabled toolchains (respects ENABLE_TC1~4)
        echo "[k230] setup: downloading enabled toolchains..."
        [ "$ENABLE_TC1" = "1" ] && download_tc1
        [ "$ENABLE_TC2" = "1" ] && download_tc2
        [ "$ENABLE_TC3" = "1" ] && download_tc3
        [ "$ENABLE_TC4" = "1" ] && download_tc4
        return 0
    fi

    case $target in
        tc1) download_tc1 ;;
        tc2) download_tc2 ;;
        tc3) download_tc3 ;;
        tc4) download_tc4 ;;
        *)   echo "[k230] error: unknown target '$target'" >&2; return 1 ;;
    esac
}

# ===== Command: env (show toolchain status) =====
cmd_env() {
    echo "[k230] Toolchains at $TOOLCHAIN_ROOT/"

    local pad="                     "
    local tc1_dir="$TOOLCHAIN_ROOT/$TC1_DIR"
    local tc2_dir="$TOOLCHAIN_ROOT/$TC2_DIR"
    local tc3_dir="$TOOLCHAIN_ROOT/$TC3_DIR"
    local tc4_dir="$TOOLCHAIN_ROOT/$TC4_DIR"

    local tc1_ver tc2_ver tc3_ver tc4_ver

    if tc_is_installed "$tc1_dir" "$TC1_VERSION" "$TC1_BIN_FULL"; then
        tc1_ver=$(cat "$tc1_dir/.version")
        printf "  TC1 (xuantie-5.10.4):%sINSTALLED (${tc1_ver})\n" "${pad:21}"
    else
        printf "  TC1 (xuantie-5.10.4):%sNOT INSTALLED\n" "${pad:21}"
    fi

    if tc_is_installed "$tc2_dir" "$TC2_VERSION" "$TC2_BIN_FULL"; then
        tc2_ver=$(cat "$tc2_dir/.version")
        printf "  TC2 (xuantie-6.6.0):%s  INSTALLED (${tc2_ver})\n" "${pad:20}"
    else
        printf "  TC2 (xuantie-6.6.0):%s  NOT INSTALLED\n" "${pad:20}"
    fi

    if tc_is_installed "$tc3_dir" "$TC3_VERSION" "$TC3_BIN_FULL"; then
        tc3_ver=$(cat "$tc3_dir/.version")
        printf "  TC3 (musl):%s           INSTALLED (${tc3_ver})\n" "${pad:21}"
    else
        printf "  TC3 (musl):%s           NOT INSTALLED\n" "${pad:21}"
    fi

    if tc_is_installed "$tc4_dir" "$TC4_VERSION" "$TC4_BIN_FULL"; then
        tc4_ver=$(cat "$tc4_dir/.version")
        printf "  TC4 (ilp32):%s          INSTALLED (${tc4_ver})\n" "${pad:20}"
    else
        printf "  TC4 (ilp32):%s          NOT INSTALLED\n" "${pad:20}"
    fi
}

# ===== Command dispatcher =====
case $CMD in
    setup)
        cmd_setup "$2"
        ;;
    rtos)
        # Download TC1 + TC3, setup RTOS env, exec bash
        download_tc1
        download_tc3
        setup_env rtos
        exec bash
        ;;
    linux)
        # Download TC2, setup Linux env, exec bash
        download_tc2
        setup_env linux
        exec bash
        ;;
    env)
        cmd_env
        ;;
    "")
        echo "Usage: k230 <command>"
        echo ""
        echo "Commands:"
        echo "  setup       Download all enabled toolchains (respects ENABLE_TC1~4)"
        echo "  setup tc1   Download TC1 only (xuantie-5.10.4)"
        echo "  setup tc2   Download TC2 only (xuantie-6.6.0)"
        echo "  setup tc3   Download TC3 only (musl)"
        echo "  setup tc4   Download TC4 only (ilp32)"
        echo "  setup all   Download all 4 toolchains"
        echo "  rtos        Download TC1+TC3, setup RTOS env, start shell"
        echo "  linux       Download TC2, setup Linux env, start shell"
        echo "  env         Show installed toolchain status"
        echo ""
        echo "URL overrides:"
        echo "  tc1_urls=url1,url2    Override TC1 download URLs"
        echo "  tc2_urls=url1,url2    Override TC2 download URLs"
        echo "  tc3_urls=url1,url2    Override TC3 download URLs"
        echo "  tc4_urls=url1,url2    Override TC4 download URLs"
        echo "  linux_urls=...        Override TC2 URLs (backward compat)"
        echo "  rtos_urls=...         Override TC1+TC3 URLs (backward compat)"
        ;;
    *)
        echo "[k230] error: unknown command '$CMD'" >&2
        echo "Run 'k230' with no args for usage." >&2
        exit 1
        ;;
esac
